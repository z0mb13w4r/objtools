static convert_t ecSHNINDEX[] = {
  {"UND",  SHN_UNDEF},
  {"ABS",  SHN_ABS},
  {"COM",  SHN_COMMON},

  {0, 0}
};

const char* get_SHNINDEX(const pick_t st_shndx) {
  static char buff[32];

  const char* def = strpicknull(ecSHNINDEX, st_shndx);
  if (NULL == def) {
    snprintf(buff, sizeof(buff), "%3ld", st_shndx);
  } else {
    snprintf(buff, sizeof(buff), "%3s", def);
  }

  return buff;
}

