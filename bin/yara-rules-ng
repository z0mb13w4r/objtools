#!/bin/bash

VERSION=1.0
SCRIPTNAME=$(basename "$0")

CPBIN=/usr/bin/cp
JQBIN=/usr/bin/jq
LSBIN=/usr/bin/ls
RMBIN=/usr/bin/rm
CATBIN=/usr/bin/cat
GITBIN=/usr/bin/git
CURLBIN=/usr/bin/curl
SUDOBIN=/usr/bin/sudo
WGETBIN=/usr/bin/wget
YARABIN=/usr/bin/yara
MKDIRBIN=/usr/bin/mkdir
UNZIPBIN=/usr/bin/unzip

GITHUB=https://github.com/

TMP=/tmp/
USRLOCAL=/usr/local/
YARAFORGE=yara-forge/
USRYARARULES=${USRLOCAL}yara-rules/index.yar
USRYARAFORGECORE=${USRLOCAL}${YARAFORGE}packages/core/yara-rules-core.yar
USRYARAFORGEEXTENDED=${USRLOCAL}${YARAFORGE}packages/extended/yara-rules-extended.yar
USRYARAZOMBIE=${USRLOCAL}yara-z0mb13w4r/index.yar

function show_usage() {
  ${CATBIN} << EOF
Usage: ${SCRIPTNAME} v${VERSION}
EXAMPLES:
  ${SCRIPTNAME} <source/path/name>
  ${SCRIPTNAME} <source/path/name> {-c|--check} <source/path/yara/rule>
  ${SCRIPTNAME} {-r|--yara-rules} <source/path/name>
  ${SCRIPTNAME} {-f|--yara-forge} <source/path/name>
  ${SCRIPTNAME} {-u|--update}
  ${SCRIPTNAME} {-v|--version}
  ${SCRIPTNAME} {-h|--help}
EOF
}

function show_version() {
  echo "${SCRIPTNAME} v${VERSION}"
}

function yara_run() {
  if [ -e "${1}" ]; then
    ${YARABIN} -w "${1}" "${2}"
  fi
}

function yara_capev2() {
  yara_run "${USRLOCAL}yara-capev2/index.yar" "${*}"
}

function yara_intezer() {
  yara_run "${USRLOCAL}yara-intezer/index.yar" "${*}"
}

function yara_neo23x0() {
  yara_run "${USRLOCAL}yara-neo23x0/index.yar" "${*}"
}

function yara_opensrc() {
  yara_run "${USRLOCAL}yara-opensrc/index.yar" "${*}"
}

function yara_exact() {
  GITHUBTXT=${TMP}yara-forge-rules.txt

  ${RMBIN} -v ${TMP}yara-forge-rules*
  ${RMBIN} -vr ${TMP}${YARAFORGE}
  ${WGETBIN} https://api.github.com/repos/${1}/releases/latest -O ${GITHUBTXT}
  FILES=$(${CATBIN} ${GITHUBTXT} | ${JQBIN} -r '(.assets[].browser_download_url | select(. | contains(".zip")))')

  ${WGETBIN} -P ${TMP} ${FILES}

  FILES=($(${LSBIN} -1 ${TMP}yara-forge-rules*.zip))
  for i in "${FILES[@]}"; do
    #echo ${i}
    ${UNZIPBIN} ${i} -d ${TMP}${YARAFORGE}
  done

  ${SUDOBIN} ${CPBIN} -Rfv ${TMP}${YARAFORGE} ${USRLOCAL}/
}

function yara_fetch() {
  if [ -d "${USRLOCAL}${2}" ]; then
    cd ${USRLOCAL}${2} && ${SUDOBIN} ${GITBIN} pull
  else
    ${SUDOBIN} ${GITBIN} clone ${GITHUB}${1} ${USRLOCAL}${2}
  fi
}

POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
  case ${1} in
    -c|--check)
      ARG_YARA_CHECK="${2}"
      shift # past argument
      shift # past value
      ;;
    -r|--yara-rules)
      ARG_YARA_RULES=YES
      shift # past argument
      ;;
    -f|--yara-forge)
      ARG_YARA_FORGE=YES
      shift # past argument
      ;;
    -z|--yara-z0mb13w4r)
      ARG_YARA_ZOMBIE=YES
      shift # past argument
      ;;
    -u|--update)
      ARG_YARA_UPDATE=YES
      shift # past argument
      ;;
    -h|--help)
      ARG_HELP=YES
      shift # past argument
      ;;
    -v|--version)
      ARG_VERSION=YES
      shift # past argument
      ;;
    -*|--*)
      echo "Unknown option ${1}"
      exit 1
      ;;
    *)
      POSITIONAL_ARGS+=("${1}") # save positional arg
      shift # past argument
      ;;
  esac
done

set -- "${POSITIONAL_ARGS[@]}" # restore positional parameters

if [ "${ARG_HELP}" == "YES" ]; then
  show_usage
  exit 0
elif [ "${ARG_VERSION}" == "YES" ]; then
  show_version
  exit 0
fi

if [ "${ARG_YARA_UPDATE}" == "YES" ]; then
  yara_exact YARAHQ/yara-forge
  yara_fetch Yara-Rules/rules.git yara-rules
  yara_fetch z0mb13w4r/yara-rules.git yara-z0mb13w4r
  #yara_fetch Neo23x0/signature-base.git yara-neo23x0
  #yara_fetch intezer/yara-rules.git yara-intezer
  #yara_fetch kevoreilly/CAPEv2.git yara-capev2
  #yara_fetch mikesxrs/Open-Source-YARA-rules.git yara-opensrc
elif [ ! -z "${POSITIONAL_ARGS}" ]; then
  if [ ! -z "${ARG_YARA_CHECK}" ]; then
    yara_run "${ARG_YARA_CHECK}" "${POSITIONAL_ARGS}"
  elif [ "${ARG_YARA_RULES}" == "YES" ]; then
    yara_run "${USRYARARULES}" "${POSITIONAL_ARGS}"
  elif [ "${ARG_YARA_FORGE}" == "YES" ]; then
    yara_run "${USRYARAFORGECORE}" "${POSITIONAL_ARGS}"
    yara_run "${USRYARAFORGEEXTENDED}" "${POSITIONAL_ARGS}"
  elif [ "${ARG_YARA_ZOMBIE}" == "YES" ]; then
    yara_run "${USRYARAZOMBIE}" "${POSITIONAL_ARGS}"
  else
    yara_run "${USRYARARULES}" "${*}"
    yara_run "${USRYARAFORGECORE}" "${*}"
    yara_run "${USRYARAFORGEEXTENDED}" "${*}"
    yara_run "${USRYARAZOMBIE}" "${*}"

    #yara_neo23x0 "${*}"
    #yara_intezer "${*}"
    #yara_capev2 "${*}"
    #yara_opensrc "${*}"
  fi
else
  show_usage
  exit 1
fi

exit 0
