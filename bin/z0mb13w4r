#!/bin/bash

VERSION=1.0
SCRIPTNAME=$(basename "$0")

CATBIN=/usr/bin/cat
WGETBIN=/usr/bin/wget

function show_usage() {
  ${CATBIN} << EOF
Usage: ${SCRIPTNAME} v${VERSION}
EXAMPLES:
  ${SCRIPTNAME} {-u|--update}
  ${SCRIPTNAME} {-V|--verbose}
  ${SCRIPTNAME} {-v|--version}
  ${SCRIPTNAME} {-h|--help}
EOF
}

function fetch_gdrive() {
  ${WGETBIN} --no-check-certificate "https://drive.google.com/uc?export=download&id=${1}" -O ${2}
}

POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
  case ${1} in
    -d|--develop)
      ARG_DEVELOP=YES
      shift # past argument
      ;;
    -u|--update)
      ARG_UPDATE=YES
      shift # past argument
      ;;
    -h|--help)
      ARG_HELP=YES
      shift # past argument
      ;;
    -v|--version)
      ARG_VERSION=YES
      shift # past argument
      ;;
    -V|--verbose)
      YARA_ARGS+=' -s'
      shift # past argument
      ;;
    -*|--*)
      echo "Unknown option ${1}"
      exit 1
      ;;
    *)
      POSITIONAL_ARGS+=("${1}") # save positional arg
      shift # past argument
      ;;
  esac
done

set -- "${POSITIONAL_ARGS[@]}" # restore positional parameters

if [ "${ARG_HELP}" == "YES" ]; then
  show_usage
  exit 0
elif [ "${ARG_VERSION}" == "YES" ]; then
  show_version
  exit 0
fi


#${WGETBIN} https://github.com/WerWolv/ImHex/releases/download/v1.38.1/imhex-1.38.1-Ubuntu-24.04-x86_64.deb
#${WGETBIN} https://github.com/z0mb13w4r/objtools/releases/download/v1.4/objtools-1.4-ubuntu-24.04-amd64.deb

if [ "${ARG_DEVELOP}" == "YES" ]; then
  #${WGETBIN} --no-check-certificate 'https://drive.google.com/uc?export=download&id=1LDqJ_y3mdUH7Xm9JkBDmc7laucPE54IB' -O /tmp/NOTE
  #${WGETBIN} --no-check-certificate 'https://drive.google.com/uc?export=download&id=159scb5AIllJBETYbpiatgJMCcwqLtHqs' -O $(${CATBIN} /tmp/NOTE)
  fetch_gdrive "1LDqJ_y3mdUH7Xm9JkBDmc7laucPE54IB" "/tmp/NOTE"
  fetch_gdrive "159scb5AIllJBETYbpiatgJMCcwqLtHqs" "$(${CATBIN} /tmp/NOTE)"
fi

