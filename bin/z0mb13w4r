#!/bin/bash

# curl -O https://raw.githubusercontent.com/z0mb13w4r/objtools/master/bin/z0mb13w4r

VERSION=1.0
SCRIPTNAME=$(basename "$0")

TMP=/tmp/

CATBIN=/usr/bin/cat
CUTBIN=/usr/bin/cut
DPKGBIN=/usr/bin/dpkg
GREPBIN=/usr/bin/grep
SUDOBIN=/usr/bin/sudo
WGETBIN=/usr/bin/wget

function show_usage() {
  ${CATBIN} << EOF
Usage: ${SCRIPTNAME} v${VERSION}
EXAMPLES:
  ${SCRIPTNAME} {-u|--update}
  ${SCRIPTNAME} {-d|--develop}
  ${SCRIPTNAME} {-v|--version}
  ${SCRIPTNAME} {-h|--help}
EOF
}

function fetch_gdrive() {
  ${WGETBIN} --no-check-certificate "https://drive.google.com/uc?export=download&id=${1}&confirm=t" -O ${TMP}${2}
}

function fetch_github() {
  ${WGETBIN} https://github.com/${1}/${2} -O ${TMP}${2}
}

function fetch_item() {
  echo $(${GREPBIN} ${1} ${TMP}NOTE | ${CUTBIN} -d ' ' -f ${2})
}

function debian() {
  ${SUDOBIN} ${DPKGBIN} -i ${TMP}${1}
}

POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
  case ${1} in
    -d|--develop)
      ARG_DEVELOP=YES
      shift # past argument
      ;;
    -u|--update)
      ARG_UPDATE=YES
      shift # past argument
      ;;
    -h|--help)
      ARG_HELP=YES
      shift # past argument
      ;;
    -v|--version)
      ARG_VERSION=YES
      shift # past argument
      ;;
    -*|--*)
      echo "Unknown option ${1}"
      exit 1
      ;;
    *)
      POSITIONAL_ARGS+=("${1}") # save positional arg
      shift # past argument
      ;;
  esac
done

set -- "${POSITIONAL_ARGS[@]}" # restore positional parameters

if [ "${ARG_HELP}" == "YES" ]; then
  show_usage
  exit 0
elif [ "${ARG_VERSION}" == "YES" ]; then
  show_version
  exit 0
fi

if [ "${ARG_DEVELOP}" == "YES" ]; then
  fetch_gdrive "1LDqJ_y3mdUH7Xm9JkBDmc7laucPE54IB" "NOTE"
  fetch_gdrive "$(fetch_item 'DEVELOP' '2')" "$(fetch_item 'DEVELOP' '1')"
  debian "$(fetch_item 'DEVELOP' '1')"
elif [ "${ARG_UPDATE}" == "YES" ]; then
  fetch_gdrive "1LDqJ_y3mdUH7Xm9JkBDmc7laucPE54IB" "NOTE"
  fetch_github "$(fetch_item 'GITHUB1' '2')" "$(fetch_item 'GITHUB1' '1')"
  fetch_github "$(fetch_item 'GITHUB2' '2')" "$(fetch_item 'GITHUB2' '1')"
  debian "$(fetch_item 'GITHUB1' '1')"
  debian "$(fetch_item 'GITHUB2' '1')"
fi

