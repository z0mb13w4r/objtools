#!/bin/bash

VERSION=1.1
SCRIPTNAME=$(basename "$0")

JQBIN=/usr/bin/jq
MVBIN=/usr/bin/mv
RMBIN=/usr/bin/rm
TRBIN=/usr/bin/tr
APTBIN=/usr/bin/apt
CATBIN=/usr/bin/cat
CUTBIN=/usr/bin/cut
GITBIN=/usr/bin/git
DPKGBIN=/usr/bin/dpkg
GREPBIN=/usr/bin/grep
SUDOBIN=/usr/bin/sudo
WGETBIN=/usr/bin/wget
CHMODBIN=/usr/bin/chmod
MKDIRBIN=/usr/bin/mkdir
UNZIPBIN=/usr/bin/7z
REMNUXBIN=/usr/local/bin/remnux
LSBRELEASEBIN=/usr/bin/lsb_release

TMP=/tmp/
CYBERCHEF=/usr/local/cyberchef/

GITHUBNAM=${TMP}github.nam
GITHUBTAG=${TMP}github.tag
GITHUBTXT=${TMP}github.txt
GITHUBZIP=${TMP}github.zip
GITHUBVER=${TMP}github.ver

function do_remnux() {
  ${WGETBIN} https://REMnux.org/remnux
  ${CHMODBIN} +x remnux
  ${SUDOBIN} ${MVBIN} remnux ${REMNUXBIN}

  ${SUDOBIN} ${REMNUXBIN} install
}

function do_upgrade() {
  ${SUDOBIN} ${APTBIN} update
  ${SUDOBIN} ${APTBIN} upgrade -y
}

function do_config() {
  echo -n "Your name: "
  read -r USERNAME
  echo -n "Your email: "
  read -r EMAILADDR

  ${GITBIN} config --global user.name "'${USERNAME}'"
  ${GITBIN} config --global user.email "'${EMAILADDR}'"
}

function do_files() {
  VIMTXT=${HOME=/home/remnux}/.vimrc

  echo 'set number' > ${VIMTXT}
  echo 'set autoindent' >> ${VIMTXT}
  echo 'set hlsearch' >> ${VIMTXT}
  echo 'set tabstop=2' >> ${VIMTXT}
  echo 'set softtabstop=2' >> ${VIMTXT}
  echo 'set shiftwidth=2' >> ${VIMTXT}
  echo 'set expandtab' >> ${VIMTXT}
  echo >> ${VIMTXT}
  echo '" Press F4 to toggle highlighting on/off, and show current value.' >> ${VIMTXT}
  echo ':noremap <F4> :set hlsearch! hlsearch?<CR>' >> ${VIMTXT}
  echo >> ${VIMTXT}
  echo '" Press return to temporarily get out of the highlighted search.' >> ${VIMTXT}
  echo ':nnoremap <CR> :nohlsearch<CR><CR>' >> ${VIMTXT}
  echo >> ${VIMTXT}
  echo '" Highlight trailing whitespaces' >> ${VIMTXT}
  echo ':highlight TrailWhitespace ctermbg=red guibg=red' >> ${VIMTXT}
  echo ':match TrailWhitespace /\s\+$\| \+\ze\t/' >> ${VIMTXT}

  ${GITBIN} config --global core.editor vim
  ${GITBIN} config --global core.pager 'less -FRSX'
  ${GITBIN} config --global core.abbrev 12
  ${GITBIN} config --global color.ui auto
  ${GITBIN} config --global merge.tool vimdiff
  ${GITBIN} config --global difftool.prompt false
  ${GITBIN} config --global alias.unstage 'reset HEAD --'
  ${GITBIN} config --global alias.log-all 'log --graph --stat --patch --ignore-space-change'
  ${GITBIN} config --global alias.last 'log -1 HEAD'
  ${GITBIN} config --global pretty.fixes 'Fixes: %h (\"%s\")'
  ${GITBIN} config --global push.default simple
}

function do_debians() {
  ${SUDOBIN} ${APTBIN} install -y binutils-dev
  ${SUDOBIN} ${APTBIN} install -y vim-gtk3 git git-doc git-email
  ${SUDOBIN} ${APTBIN} install -y python3-scapy python3-pyx
}

function do_objtools() {
#  ${LSBRELEASEBIN} -a | ${GREPBIN} Release | ${CUTBIN} -d ':' -f 2 | ${TRBIN} -d '[[:space:]]' > ${GITHUBVER}

  ${WGETBIN} https://api.github.com/repos/z0mb13w4r/objtools/releases/latest -O ${GITHUBTXT}

  ${CATBIN} ${GITHUBTXT} | ${JQBIN} -r '(.tag_name)' > ${GITHUBTAG}
  ${CATBIN} ${GITHUBTXT} | ${JQBIN} -r '(.assets[].name | select(. | contains("24.04-amd64.deb")))' > ${GITHUBNAM}
  ${CATBIN} ${GITHUBTXT} | ${JQBIN} -r '(.assets[].browser_download_url | select(. | contains("24.04-amd64.deb")))' > ${GITHUBZIP}

  NAME=${TMP}$(${CATBIN} ${GITHUBNAM})

  ${RMBIN} ${NAME}
  ${WGETBIN} -P ${TMP} $(${CATBIN} ${GITHUBZIP})

  ${SUDOBIN} ${DPKGBIN} -i ${NAME}
}

function do_cyberchef() {
  ${WGETBIN} https://api.github.com/repos/gchq/cyberchef/releases/latest -O ${GITHUBTXT}

  ${CATBIN} ${GITHUBTXT} | ${JQBIN} -r '(.assets[].name | select(. | contains(".zip")))' > ${GITHUBNAM}
  ${CATBIN} ${GITHUBTXT} | ${JQBIN} -r '(.assets[].browser_download_url | select(. | contains(".zip")))' > ${GITHUBZIP}

  NAME=${TMP}$(${CATBIN} ${GITHUBNAM})

  ${RMBIN} ${NAME}
  ${SUDOBIN} ${RMBIN} -rf ${CYBERCHEF}
  ${SUDOBIN} ${MKDIRBIN} -p ${CYBERCHEF}
  ${WGETBIN} -P ${TMP} $(${CATBIN} ${GITHUBZIP})

  ${SUDOBIN} ${UNZIPBIN} x ${NAME} -o${CYBERCHEF}
}

function show_usage() {
  ${CATBIN} << EOF
Usage: ${SCRIPTNAME} v${VERSION}
EXAMPLES:
  ${SCRIPTNAME} {-u|--update}
  ${SCRIPTNAME} {-i|--install}
  ${SCRIPTNAME} {-v|--version}
  ${SCRIPTNAME} {-h|--help}
EOF
}

function show_version() {
  echo ${SCRIPTNAME} v${VERSION}
}

while [[ $# -gt 0 ]]; do
  case ${1} in
    config)
      ARG_CONFIG=YES
      shift # past argument
      ;;
    install)
      ARG_INSTALL=YES
      shift # past argument
      ;;
    update)
      ARG_UPDATE=YES
      shift # past argument
      ;;
    help)
      ARG_HELP=YES
      shift # past argument
      ;;
    version)
      ARG_VERSION=YES
      shift # past argument
      ;;
    *)
      echo "Unknown option ${1}"
      exit 1
      ;;
  esac
done

if [ "${ARG_HELP}" == "YES" ]; then
  show_usage
  exit 0
elif [ "${ARG_VERSION}" == "YES" ]; then
  show_version
  exit 0
elif [ "${ARG_INSTALL}" == "YES" ]; then
  do_upgrade
  do_debians
  do_objtools
  do_remnux
  #do_cyberchef
  do_files
elif [ "${ARG_UPDATE}" == "YES" ]; then
  do_upgrade
  do_remnux
elif [ "${ARG_CONFIG}" == "YES" ]; then
  do_config
fi

